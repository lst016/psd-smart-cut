{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://psd-smart-cut.local/schemas/region.schema.json",
  "title": "RegionModel",
  "description": "Region contract for V2. Regions describe page structure and module boundaries before component export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "region_id",
    "region_key",
    "region_type",
    "display_name",
    "bounds"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "region_id": {
      "type": "string",
      "minLength": 1
    },
    "region_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "region_type": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "bounds": {
      "$ref": "#/$defs/box"
    },
    "parent_region_id": {
      "type": ["string", "null"]
    },
    "child_region_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "component_instance_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "default": []
    }
  },
  "$defs": {
    "box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["screenshot", "psd_artboard", "psd_layer", "analysis"]
        },
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string" }
      }
    }
  }
}
