{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://psd-smart-cut.local/schemas/page.schema.json",
  "title": "PageModel",
  "description": "Top-level page contract for V2. Pages are the main machine-readable entrypoint and reference region structure plus component instances.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "page_id",
    "page_key",
    "page_type",
    "display_name",
    "source",
    "viewport",
    "regions",
    "component_instances"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "page_id": {
      "type": "string",
      "minLength": 1
    },
    "page_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "page_type": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "viewport": {
      "$ref": "#/$defs/box"
    },
    "subpages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subpage"
      },
      "default": []
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/regionRef"
      }
    },
    "component_instances": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/componentInstance"
      },
      "default": []
    },
    "analysis_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileRef"
      },
      "default": []
    }
  },
  "$defs": {
    "box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    },
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screenshot_path"],
      "properties": {
        "screenshot_path": { "type": "string", "minLength": 1 },
        "psd_path": { "type": "string" },
        "artboard_ids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "subpage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subpage_id", "subpage_key", "display_name"],
      "properties": {
        "subpage_id": { "type": "string", "minLength": 1 },
        "subpage_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "display_name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" }
      }
    },
    "regionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region_id", "region_key", "region_type", "bounds"],
      "properties": {
        "region_id": { "type": "string", "minLength": 1 },
        "region_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "region_type": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" },
        "bounds": { "$ref": "#/$defs/box" },
        "child_region_ids": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "componentInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instance_id", "component_id", "region_id", "bounds"],
      "properties": {
        "instance_id": { "type": "string", "minLength": 1 },
        "component_id": { "type": "string", "minLength": 1 },
        "region_id": { "type": "string", "minLength": 1 },
        "bounds": { "$ref": "#/$defs/box" },
        "state": { "type": "string" },
        "text_overrides": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "resource_overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["part", "resource_id"],
            "properties": {
              "part": { "type": "string", "minLength": 1 },
              "resource_id": { "type": "string", "minLength": 1 }
            }
          },
          "default": []
        }
      }
    }
  }
}
