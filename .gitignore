# PSD Smart Cut - 测试配置

[pytest]
testpaths = tests skills
python_files = test_*.py
python_classes = Test*
python_functions = test_*
addopts = -v --tb=short

# Python
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/

# Logs
logs/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Test
.pytest_cache/
.coverage
htmlcov/

# Local PSD inputs and generated outputs
input/*
!input/real-psd/
input/real-psd/*
!input/real-psd/.gitkeep
output/
